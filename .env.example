# ════════════════════════════════════════════════════════════════
# TripSafe Knowledge Bot v2 — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# ════════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────────
APP_ENV=development            # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-different-long-random-string
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# ── Database ────────────────────────────────────────────────────
# Production: postgresql+asyncpg://user:pass@host:5432/dbname
# Dev fallback: sqlite+aiosqlite:///./tripsafe_dev.db
DATABASE_URL=postgresql+asyncpg://tripsafe:tripsafe@postgres:5432/tripsafe

# ── Redis (rate limiting, future caching) ───────────────────────
REDIS_URL=redis://redis:6379/0

# ── Anthropic / Claude ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-replace-me
# Bootstrap default; admins can override via Admin Portal → System Prompt / Model
DEFAULT_CHAT_MODEL=claude-haiku-4-5

# ── Google OAuth (bootstrap; admins can override via Admin Portal) ─
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/api/v1/auth/google/callback

# ── Admin seed (whitelist; these emails auto-become admin on login) ─
ADMIN_SEED_EMAILS=vulli.pruthvi@tripjack.com,vullipruthvi@gmail.com

# ── RAG / FAISS ─────────────────────────────────────────────────
FAISS_INDEX_DIR=./faiss_store
UPLOADS_DIR=./uploads
RAG_TOP_K=20

# Embedding provider:
#   "local"  → sentence-transformers running in-container. Free, private,
#              but ~90 MB one-time model download (painful behind corporate proxies).
#   "openai" → OpenAI's embeddings API. Used ONLY for embeddings; Claude still
#              handles all chat answers. Requires OPENAI_API_KEY below.
#              ~$0.02 per million tokens (negligible cost), no downloads.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Dev-only: set to true if behind a corporate TLS-intercepting proxy
# (Zscaler etc.) that breaks the huggingface.co cert chain. Never enable
# in production — AWS Fargate has direct internet egress.
EMBEDDING_DISABLE_SSL=false

# ── CORS (production must be specific) ──────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Rate limiting ───────────────────────────────────────────────
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_AUTH=10/minute

# ── AWS (production only) ───────────────────────────────────────
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_SECRETS_MANAGER_PREFIX=tripsafe/prod/
